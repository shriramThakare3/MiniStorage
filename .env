# .env — development defaults
# Copy this file to the project root before running docker compose.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=storageuser
POSTGRES_PASSWORD=storagepass
POSTGRES_DB=ministorage
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT=/app/storage
MAX_UPLOAD_SIZE_MB=100

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
